---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

// Content comes from src/content/pages/home.md — see that file to edit text.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const entry = await getEntry('pages', 'home');
const { Content } = await render(entry);
const f = entry.data;
const id = f.identity ?? {};
// Keep the name on one line in the big heading
const nameNoBreak = (f.name ?? '').replace(/ /g, ' ');
---
<BaseLayout title={f.title} description={f.description}>
  <!-- Hero -->
  <div class="hero-wrap">
  <section class="shell hero">
    <div>
      <img class="portrait" src={`${base}/images/${f.portrait ?? 'portrait.jpg'}`}
        width="500" height="282" alt={f.name} />
    </div>
    <div>
      {f.eyebrow && <p class="eyebrow">{f.eyebrow}</p>}
      <h1 class="hero__title" set:html={nameNoBreak}></h1>
      {f.role && <p class="hero__role">{f.role}</p>}
      {f.lead && <p class="lead">{f.lead}</p>}
    </div>
  </section>
  </div>

  <!-- About (from home.md body) -->
  <section class="section">
    <div class="shell measure prose">
      <Content />
    </div>
  </section>

  <!-- Explore cards -->
  <section class="section">
    <div class="shell">
      <h2>Explore</h2>
      <div class="grid grid--2" style="margin-top:1.5rem;">
        <a class="card" href={`${base}/applied-linguistics-motivation/`}>
          <p class="eyebrow" style="margin-bottom:0.4rem;">Research</p>
          <h3>Applied Linguistics &amp; Motivation</h3>
          <p class="card__meta">
            Vision, socialization, and progression in Chinese language learner
            motivation.
          </p>
          <span class="card__cta">Read the research →</span>
        </a>
        <a class="card" href={`${base}/language-pedagogy/`}>
          <p class="eyebrow" style="margin-bottom:0.4rem;">Teaching</p>
          <h3>Language Pedagogy</h3>
          <p class="card__meta">
            Textbooks, edited volumes, and courses in Chinese as a foreign
            language.
          </p>
          <span class="card__cta">See the work →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact / facts (from home.md identity) -->
  <section class="section">
    <div class="shell measure">
      <h2>Contact &amp; profile</h2>
      <ul class="facts" style="margin-top:1.25rem;">
        {id.email && (
          <li><span class="facts__k">Email</span><span><a href={`mailto:${id.email}`}>{id.email}</a></span></li>
        )}
        {id.phone && (
          <li><span class="facts__k">Phone</span><span>{id.phone}</span></li>
        )}
        {id.office && (
          <li><span class="facts__k">Office</span><span>{id.office}</span></li>
        )}
        {id.department && (
          <li><span class="facts__k">Department</span><span>{id.department}</span></li>
        )}
        {(id.hamiltonUrl || id.semanticScholarUrl) && (
          <li>
            <span class="facts__k">Profiles</span>
            <span>
              {id.hamiltonUrl && <a href={id.hamiltonUrl}>Hamilton</a>}
              {id.hamiltonUrl && id.semanticScholarUrl && ' · '}
              {id.semanticScholarUrl && <a href={id.semanticScholarUrl}>Semantic Scholar</a>}
            </span>
          </li>
        )}
      </ul>
    </div>
  </section>
</BaseLayout>
