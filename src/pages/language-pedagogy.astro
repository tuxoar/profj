---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import { getEntry } from 'astro:content';

// Content comes from src/content/pages/language-pedagogy.md
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const entry = await getEntry('pages', 'language-pedagogy');
const { Content } = await entry.render();
const f = entry.data;
---
<BaseLayout title={f.title} description={f.description}>
  <section class="shell measure section">
    {f.eyebrow && <p class="eyebrow">{f.eyebrow}</p>}
    <h1>{f.heading}</h1>
    {f.lead && <p class="lead">{f.lead}</p>}
  </section>

  <!-- Approach (from the .md body) -->
  <section class="shell measure section prose">
    <Content />
  </section>

  {f.books && (
    <section class="shell section">
      <div class="measure"><h2>Books</h2></div>
      <div class="shell" style="padding-inline:0; margin-top:1.5rem;">
        {f.books.map((b) => (
          <div class="book">
            {b.cover
              ? <img class="book__cover" src={`${base}/images/${b.cover}`} alt={`Cover of ${b.title}`} />
              : <Placeholder variant="cover" label="Book cover" file="images/your-cover.jpg" />}
            <div>
              <h3 style="margin-bottom:0.35rem;">{b.title}</h3>
              <p class="card__meta">{b.meta}</p>
              <p>{b.blurb}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {f.scholarship && (
    <section class="shell measure section">
      <h2>Selected pedagogy scholarship</h2>
      <ul class="pub-list" style="margin-top:1.5rem;">
        {f.scholarship.map((p) => (
          <li>
            <span class="pub-title">{p.title}</span>
            <span class="pub-meta" set:html={p.meta}></span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {f.courses && (
    <section class="shell measure section">
      <h2>Courses taught</h2>
      <p class="card__meta" style="margin-bottom:1.1rem;">Selected courses at Hamilton College.</p>
      <ul class="pills">
        {f.courses.map((c) => <li>{c}</li>)}
      </ul>
    </section>
  )}
</BaseLayout>
