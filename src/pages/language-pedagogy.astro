---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
---
<BaseLayout
  title="Language Pedagogy — Junqing (Jessie) Jia"
  description="Junqing Jia's work in Chinese language pedagogy: textbooks, edited volumes, and courses in Chinese as a foreign language at Hamilton College."
>
  <section class="shell measure section">
    <p class="eyebrow">Teaching</p>
    <h1>Language Pedagogy</h1>
    <p class="lead">
      I design materials and courses for Chinese learners at every level, turning
      research on motivation into classrooms — and textbooks — that ask students
      to <em>do</em> things in Chinese.
    </p>
  </section>

  <section class="shell measure section">
    <h2>Approach</h2>
    <p>
      My pedagogy grows directly out of my research: I develop materials for
      Chinese learners of various levels with the goal of transforming students
      into lifelong, self-motivated, and effective learners. Drawing on the
      <strong>performed-culture</strong> approach, I build courses around
      purposeful action in authentic cultural contexts, so that learners rehearse
      real roles rather than memorize decontextualized forms.
    </p>
  </section>

  <section class="shell section">
    <div class="measure"><h2>Books</h2></div>

    <div class="shell" style="padding-inline:0; margin-top:1.5rem;">
      <div class="book">
        <Placeholder variant="cover" label="Book cover" file="images/workplace-cover.jpg" />
        <div>
          <h3 style="margin-bottom:0.35rem;">
            Negotiating the Chinese Workplace: An Integrated Course in Advanced Chinese
          </h3>
          <p class="card__meta">Textbook · 2023</p>
          <p>
            An advanced-level, integrated Chinese course that prepares students to
            operate in professional Chinese-language settings — reading,
            listening, and performing the language of the contemporary workplace.
          </p>
        </div>
      </div>

      <div class="book">
        <Placeholder variant="cover" label="Book cover" file="images/performed-culture-cover.jpg" />
        <div>
          <h3 style="margin-bottom:0.35rem;">
            Performed Culture in Action to Teach Chinese as a Foreign Language
          </h3>
          <p class="card__meta">Co-edited with Jianfen Wang · Routledge · 2022</p>
          <p>
            A co-edited volume bringing together approaches that put performed
            culture at the center of teaching Chinese as a foreign language,
            connecting theory to concrete classroom practice.
          </p>
        </div>
      </div>

      <div class="book">
        <Placeholder variant="cover" label="Book cover" file="images/perform-suzhou-cover.jpg" />
        <div>
          <h3 style="margin-bottom:0.35rem;">
            Perform Suzhou / 体演苏州
          </h3>
          <p class="card__meta">With Xiaobin Jian et al. · 2018</p>
          <p>
            A performed-culture Chinese course built around the city of Suzhou,
            with units on talking about Suzhou, food and friendship, and
            sightseeing — including a teacher's guide — so learners rehearse
            culturally situated roles rather than isolated forms.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="shell measure section">
    <h2>Selected pedagogy scholarship</h2>
    <ul class="pub-list" style="margin-top:1.5rem;">
      <li>
        <span class="pub-title">
          Innovating the Design of Lower-Level Reading and Writing Curriculum for
          the Digital Age
        </span>
        <span class="pub-meta">Book chapter · Springer · 2020</span>
      </li>
      <li>
        <span class="pub-title">
          Understanding Chinese Behavioral Culture Through Cross-Cultural
          Communication
        </span>
        <span class="pub-meta">
          In <em>Incorporating Foreign Language Content in Humanities Courses</em> · 2019
        </span>
      </li>
    </ul>
  </section>

  <section class="shell measure section">
    <h2>Courses taught</h2>
    <p class="card__meta" style="margin-bottom:1.1rem;">Selected courses at Hamilton College.</p>
    <ul class="pills">
      <li>First-Year Chinese</li>
      <li>Third-Year Chinese</li>
      <li>Americans &amp; Chinese: Case Studies of Cross-Cultural Communication</li>
      <li>Exploring the Roots of Contemporary Issues in China</li>
      <li>Senior Project</li>
    </ul>
  </section>
</BaseLayout>
