---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

// Content comes from src/content/pages/applied-linguistics-motivation.md
const entry = await getEntry('pages', 'applied-linguistics-motivation');
const { Content } = await render(entry);
const f = entry.data;
---
<BaseLayout title={f.title} description={f.description}>
  <section class="shell measure section">
    {f.eyebrow && <p class="eyebrow">{f.eyebrow}</p>}
    <h1>{f.heading}</h1>
    {f.lead && <p class="lead">{f.lead}</p>}
  </section>

  <!-- Research focus (from the .md body) -->
  <section class="shell measure section prose">
    <Content />
  </section>

  {f.publications && (
    <section class="shell measure section">
      <h2>Selected publications</h2>
      <ul class="pub-list" style="margin-top:1.5rem;">
        {f.publications.map((p) => (
          <li>
            <span class="pub-title">{p.title}</span>
            <span class="pub-meta" set:html={p.meta}></span>
          </li>
        ))}
      </ul>
      {f.semanticScholarNote && (
        <p class="card__meta" style="margin-top:1.75rem;">
          A fuller list of articles and chapters is available on
          <a href="https://www.semanticscholar.org/author/Junqing-Jia/47710519">Semantic Scholar</a>.
        </p>
      )}
    </section>
  )}
</BaseLayout>
