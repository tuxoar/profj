---
import { getEntry } from 'astro:content';

// Identity comes from src/content/pages/home.md (edit it there).
const home = await getEntry('pages', 'home');
const f = home.data;
const id = f.identity ?? {};
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="shell site-footer__inner">
    <div class="site-footer__contact">
      <strong style="color: var(--ink-soft); font-family: var(--serif); font-size: var(--step-0);">
        {f.name}
      </strong>
      {f.role && <span>{f.role}</span>}
      <span>Hamilton College{id.office ? ` · ${id.office}` : ''}</span>
      {(id.email || id.phone) && (
        <span>
          {id.email && <a href={`mailto:${id.email}`}>{id.email}</a>}
          {id.email && id.phone && ' · '}
          {id.phone}
        </span>
      )}
    </div>
    <div>
      {id.hamiltonUrl && (
        <p style="margin:0;">
          <a href={id.hamiltonUrl}>Hamilton profile</a>
        </p>
      )}
      <p style="margin:0.25rem 0 0;">&copy; {year} {f.name}</p>
    </div>
  </div>
</footer>
